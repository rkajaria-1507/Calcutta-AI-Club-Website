# Server-side Anthropic key for the AI surfaces (profile generation, pitch
# matching, corpus Q&A). NEVER prefix with NEXT_PUBLIC_ — it must stay server-only.
# If unset, the app still runs: every AI call degrades to deterministic local logic.
ANTHROPIC_API_KEY=

# Optional model override (defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Base URL of the FastAPI backend, once persistence is wired (see docs/ROADMAP.md).
# Not required for the in-memory prototype.
NEXT_PUBLIC_API_URL=http://localhost:8000
