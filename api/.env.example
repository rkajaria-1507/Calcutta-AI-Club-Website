# Postgres connection string (Supabase pooled connection, port 6543 recommended for prod)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# Long random string used to sign member JWTs
JWT_SECRET=change-me-to-a-long-random-string

# Long random string required in the X-Admin-Secret header for admin endpoints
ADMIN_SECRET=change-me-to-a-long-random-string

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Server-side Anthropic key for card generation, pitch matching, and corpus Q&A.
# Optional — every AI call degrades to deterministic local logic if unset.
ANTHROPIC_API_KEY=

# Optional model override (defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6
